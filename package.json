{
  "name": "war-civ-2",
  "version": "0.1.0-mvp",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json --noEmit",
    "dev": "tsx src/main.ts",
    "replay:export": "tsx scripts/exportReplay.ts",
    "test": "vitest run",
    "test:architecture": "vitest run tests/architectureBoundaries.test.ts",
    "test:balance": "vitest run --config vitest.config.test.ts tests/balanceHarness.test.ts",
    "balance:harness": "tsx scripts/runBalanceHarness.ts",
    "balance:harness:stratified": "tsx scripts/runBalanceHarness.ts --stratified",
    "balance:validate-normal": "tsx scripts/runBalanceHarness.ts --validate",
    "balance:evaluate": "tsx scripts/evaluateBalance.ts",
    "balance:validate": "tsx scripts/validateBalanceCandidate.ts",
    "web:dev": "npm --prefix web run dev",
    "web:build": "npm --prefix web run build"
  },
  "devDependencies": {
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.6.1"
  }
}
